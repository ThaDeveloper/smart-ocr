{
  "name": "smart-ocr",
  "version": "1.0.0",
  "description": "OCR library for PNG images and both scanned and text-based PDFs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint src tests eslint.config.mjs --ext .ts",
    "lint:fix": "eslint src tests eslint.config.mjs --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" README.md",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.js",
    "sample": "npm run build && node scripts/run-sample.js",
    "test:unit": "tsc -p tsconfig.tests.json && node dist-tests/tests/ocrProcessor.test.js",
    "test": "npm run typecheck && npm run test:unit",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "ocr",
    "pdf",
    "png",
    "image",
    "tesseract",
    "pdfjs",
    "scanned-pdf",
    "text-extraction"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThaDeveloper/smart-ocr.git"
  },
  "bugs": {
    "url": "https://github.com/ThaDeveloper/smart-ocr/issues"
  },
  "homepage": "https://github.com/ThaDeveloper/smart-ocr#readme",
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.27",
    "@types/tesseract.js": "^0.0.2",
    "eslint": "^9.27.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-jsdoc": "^50.6.17",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "dependencies": {
    "canvas": "^3.1.2",
    "pdfjs-dist": "^2.16.105",
    "tesseract.js": "^6.0.1"
  },
  "engines": {
    "node": ">=18.18"
  }
}
