  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.27",
    "@types/pdf2image": "^1.2.4",
    "@types/tesseract.js": "^0.0.2",
    "eslint": "^9.27.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-jsdoc": "^50.6.17",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "canvas": "^3.1.2",
    "pdfjs-dist": "^2.16.105",
    "tesseract.js": "^6.0.1"
  }
